generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LockerStatus {
  FREE
  OCCUPIED
  MAINTENANCE
}

enum NotificationChannel {
  EMAIL
}

enum NotificationEvent {
  ALLOCATION_CREATED
  ALLOCATION_ENDED
  ALLOCATION_RENEWED
  ALLOCATION_CANCELLED
  LOCKER_MAINTENANCE
  LOCKER_FREED
  DUE_SOON
  OVERDUE
}

enum AuditEntity {
  LOCKER
  ALLOCATION
  USER
  SYSTEM
}

enum AuditAction {
  LOCKER_CREATED
  LOCKER_STATUS_CHANGED
  ALLOCATION_CREATED
  ALLOCATION_ENDED
  ALLOCATION_RENEWED
  ALLOCATION_CANCELLED
  NOTIFICATION_SENT
  DATA_IMPORT
}

enum AccessEvent {
  LOGIN
  LOGOUT
  ACCESS_DENIED
}

model User {
  id    String  @id @default(uuid())
  name  String
  email String  @unique
  phone String?

  allocations Allocation[]

  currentLockers Locker[] @relation("CurrentLockerUser")
}

model Locker {
  id String @id @default(uuid())

  floor     Int
  keyNumber Int
  lab       String?
  status    LockerStatus @default(FREE)

  currentUserId String?
  currentUser   User?   @relation("CurrentLockerUser", fields: [currentUserId], references: [id])

  allocations Allocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([floor, keyNumber])
}

model Allocation {
  id       String @id @default(uuid())
  userId   String
  lockerId String

  startAt DateTime
  dueAt   DateTime?
  endAt   DateTime?

  renewedCount Int     @default(0)
  cancelReason String?

  user   User   @relation(fields: [userId], references: [id])
  locker Locker @relation(fields: [lockerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, endAt])
  @@index([lockerId, endAt])
}

model AuditLog {
  id         String      @id @default(uuid())
  actorEmail String?
  actorName  String?
  action     AuditAction
  entity     AuditEntity
  entityId   String?
  details    String
  createdAt  DateTime    @default(now())
}

model SystemSettings {
  id String @id @default("singleton")

  // 1) regras de alocação
  allocationMonths Int     @default(6)
  allowRenewal     Boolean @default(true)
  maxRenewals      Int     @default(1)

  // 2) notificações (config real do sistema)
  notificationsEnabled Boolean @default(false)
  notificationToEmails String? // CSV: "magda@ufcspa.edu.br,gerlab@ufcspa.edu.br"

  // 3) segurança
  allowedManagerEmails       String  @default("msbrasil@ufcspa.edu.br,yorrana.marins@ufcspa.edu.br") // CSV
  requireInstitutionalDomain Boolean @default(true)

  // 4) aparência
  theme  String @default("light")
  locale String @default("pt-BR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationOutbox {
  id String @id @default(uuid())

  channel NotificationChannel @default(EMAIL)
  event   NotificationEvent

  toEmail String
  subject String
  body    String

  status String    @default("PENDING")
  sentAt DateTime?
  error  String?

  entity   AuditEntity
  entityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model AccessLog {
  id         String      @id @default(uuid())
  actorEmail String?
  event      AccessEvent
  ip         String?
  userAgent  String?
  createdAt  DateTime    @default(now())
}
